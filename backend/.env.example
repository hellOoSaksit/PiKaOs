# Copy to .env. This file is the config contract.
# Host port 5433 (compose maps 5433->5432 to avoid clashing a local Postgres on 5432)
DATABASE_URL=postgresql+psycopg://pikaos:pikaos@localhost:5433/pikaos
CRAWL_TIMEOUT=12
CRAWL_USER_AGENT=PiKaOs-SitemapBot/0.1 (+https://pikaos.local)
CRAWL_MAX_TERMS=600
DEFAULT_PASS_THRESHOLD=70
UNCLEAR_BAND=18
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Normalize text line endings in the repo (LF), with safe per-type overrides.
* text=auto

# Shell scripts MUST stay LF (docker-entrypoint.sh runs in a Linux container).
*.sh text eol=lf

# Windows batch files are CRLF.
*.bat text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

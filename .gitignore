# Public monorepo — holds PiKaOs-Core/ as a plain folder (its separate git repo was collapsed in here).
# Per-folder .gitignore files still apply (node_modules, .env, __pycache__, dist, …). These stay SEPARATE
# git repos (own remotes), so keep them ignored here:
#   PiKaOs-Docs/         = PRIVATE (internal-only docs — must never land in this public repo)
#   PiKaOs-Plugin-<Name>/ = one repo PER plugin (repo-per-plugin), each public, own remote:
#       -Knowledge -World (Core feature plugins) · -Compare -RedirectMap (standalone plugin-apps)
/PiKaOs-Docs/
/PiKaOs-Plugin-*/

# PiKaOs-Plugin/ = RUNTIME install dir Core creates at plugin-install time to hold installed plugin
# code OUTSIDE Core (Core source is never modified; in Docker this is a named volume). Never committed.
/PiKaOs-Plugin/

# Internal dev-rule / knowledge root files live in the PRIVATE PiKaOs-Docs repo (not public).
# They're symlinked back here (CLAUDE.md → PiKaOs-Docs/CLAUDE.md, etc.) so Claude Code auto-load +
# local tooling still work, but the symlinks must NOT be pushed to this public repo.
/CLAUDE.md
/AGENTS.md
/llms.txt

# Claude Code local/user state — all private (skills now live in PiKaOs-Docs/.claude/skills)
.claude/

# local tooling / MCP state (not shared)
.mcp.json
.mcp.json.*
.playwright-mcp/

# PiKaOs-UAT-Run = throwaway COPY of Core for deploy-fidelity test runs (built images, no dev bind-mount).
# Holds copied .env files → MUST never be committed. Regenerated by rsync; delete anytime.
/PiKaOs-UAT-Run/
# Core keeps ONLY the plugin SEAM files; the per-plugin folders beside them are gitignored symlinks
# into PiKaOs-App/plugins/ (created by link-plugins.sh).
/PiKaOs-Core/Frontend/src/plugins/*
!/PiKaOs-Core/Frontend/src/plugins/index.jsx
/PiKaOs-Core/Backend/app/plugins/*
!/PiKaOs-Core/Backend/app/plugins/__init__.py
!/PiKaOs-Core/Backend/app/plugins/manifest.schema.json

# Build-merge artifact — kernel + enabled-plugin requirements merged by scripts/render_requirements.py
# (regenerated on every link-plugins.sh run to match the installed plugin set). Never committed.
/PiKaOs-Core/Backend/requirements.lock

# Kernel runtime state — first-run setup state (a hash of the console code), written at boot to a local
# JSON file (NOT the DB) so the kernel works before any datastore exists. Runtime-only, never committed.
/PiKaOs-Core/Backend/data/

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
.idea/
.vscode/

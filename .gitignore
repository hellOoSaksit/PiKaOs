# Monorepo — this repo now holds PiKaOs-Core/ + PiKaOs-Docs/ + PiKaOs-App/ as plain folders
# (their separate git repos were collapsed in here). Per-folder .gitignore files still apply
# (node_modules, .env, __pycache__, dist, …). The own-app plugins under PiKaOs-Plugin/ stay
# SEPARATE git repos (their own remotes + deploy), so they remain ignored here.
/PiKaOs-Plugin/

# Claude Code local/user state (keep .claude/skills, drop the rest)
.claude/*
!.claude/skills/
.claude/settings.local.json

# local tooling / MCP state (not shared)
.mcp.json
.playwright-mcp/

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
.idea/
.vscode/

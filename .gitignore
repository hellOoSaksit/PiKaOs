# Public monorepo — holds PiKaOs-Core/ + PiKaOs-App/ as plain folders (their separate git repos
# were collapsed in here). Per-folder .gitignore files still apply (node_modules, .env, __pycache__,
# dist, …). These stay SEPARATE git repos (own remotes), so keep them ignored here:
#   PiKaOs-Docs/   = PRIVATE (internal-only docs — must never land in this public repo)
#   PiKaOs-Plugin/ = own-app plugins (Compare, RedirectMap), public, deploy separately
/PiKaOs-Docs/
/PiKaOs-Plugin/

# Internal dev-rule / knowledge root files live in the PRIVATE PiKaOs-Docs repo (not public).
# They're symlinked back here (CLAUDE.md → PiKaOs-Docs/CLAUDE.md, etc.) so Claude Code auto-load +
# local tooling still work, but the symlinks must NOT be pushed to this public repo.
/CLAUDE.md
/AGENTS.md
/llms.txt

# Claude Code local/user state — all private (skills now live in PiKaOs-Docs/.claude/skills)
.claude/

# local tooling / MCP state (not shared)
.mcp.json
.mcp.json.*
.playwright-mcp/

# UAT plugin code (P2). Real plugin folders live in PiKaOs-App/plugins/<id>/{frontend,backend}/ and are
# composed into Core via symlink at test time only (App = local UAT — see link-plugins.sh). NEVER pushed:
# Core must stay plugin-free so the public repo ships only the platform + the plugin seam.
/PiKaOs-App/plugins/
# Core keeps ONLY the seam files; the per-plugin folders beside them are gitignored symlinks into the above.
/PiKaOs-Core/Frontend/src/plugins/*
!/PiKaOs-Core/Frontend/src/plugins/index.jsx
/PiKaOs-Core/Backend/app/plugins/*
!/PiKaOs-Core/Backend/app/plugins/__init__.py
!/PiKaOs-Core/Backend/app/plugins/manifest.schema.json

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
.idea/
.vscode/

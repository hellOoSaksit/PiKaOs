# import-linter — the static gate behind plugin-architecture.md §2 + §15.
# Run from Backend/:  lint-imports
# grimp parses the source (it does NOT import/execute modules) so this needs no app deps installed.
#
# Two rules, both architectural invariants the Loader can't catch at import time:
#   1. Core ↛ plugins   (§2.1) — the Base never reaches up into a feature; remove any plugin and
#      Core still imports. As of Phase 3 there are NO exceptions: the engine reaches the knowledge
#      plugin only through the DI container (`knowledge.Retriever` contract) + the Event Bus, and the
#      worker discovers plugin jobs via the Loader's dynamic import — zero static plugin imports.
#   2. Plugin ↛ sibling plugin (§2.3) — features talk only through Core contracts, never each other.
#      Enforced in each plugin repo's OWN CI (which links the plugin into a Core checkout), NOT here:
#      a plugin-free Core checkout has no app.plugins.<id> for grimp to resolve, so listing them would
#      make lint-imports fail with "module does not exist" before any contract is even checked.
#   3. Core ↛ App composition (§2.1) — the Base never reaches up into the composition seam
#      (main/worker/modules = the PiKaOs-App layer). `plugin_loader` is the KERNEL plugin catalog
#      (discover/topo/enabled-selection), so app.core MAY import it. Inversions go through app.state / DI.

[importlinter]
root_package = app

[importlinter:contract:core-must-not-import-plugins]
name = Core (Base) must not import any plugin (§2.1)
type = forbidden
# app.core = the whole Base subpackage (Phase 1b moved infra + the core/engine layers under app/core/);
# app.{main,worker,modules,plugin_loader} = the composition seam at the app root (the future PiKaOs-App).
source_modules =
    app.main
    app.worker
    app.modules
    app.plugin_loader
    app.core
forbidden_modules =
    app.plugins

[importlinter:contract:core-must-not-import-app-composition]
name = Core (Base) must not import the App composition seam (§2.1 — Core ↛ App)
# The composition root (main/worker/modules = the PiKaOs-App layer) wires Core + plugins together; Core
# must never reach UP into it. `plugin_loader` is NOT in this list — the kernel-redesign moves the plugin
# catalog (discover/topo/enabled-selection) into the kernel, so Core-side code (composition, plugin_registry,
# the plugins router) legitimately imports it. A prior breach — core/routers/health.py importing `modules`
# for plugin_states() — was inverted via app.state (the App registers the provider at startup).
type = forbidden
source_modules =
    app.core
forbidden_modules =
    app.main
    app.worker
    app.modules

# NOTE: the plugin↛sibling-plugin independence contract lives in each plugin repo's own CI (see header #2),
# not here — a plugin-free Core checkout has no app.plugins.<id> modules for grimp to resolve.

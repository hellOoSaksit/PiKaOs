# PiKaOs — AI env (LLM + embedding providers). Copy to .env.ai.
# Consumed by the backend + worker (loaded after Backend/.env). Most LLM config is set at runtime
# from the "จัดการเครื่องมือ" tools screen + DB (encrypted); these are the .env FALLBACK used only
# when no DB connection is active. Kept separate so the AI layer can be swapped/deployed on its own.
# 🔒 = secret. Comments on their own lines (compose keeps inline ones).

# stub | ollama | openai | anthropic
LLM_PROVIDER=stub
LLM_BASE_URL=http://host.docker.internal:11434
# 🔒
OPENAI_API_KEY=
# 🔒
ANTHROPIC_API_KEY=
# stub | ollama
EMBED_PROVIDER=stub
EMBED_BASE_URL=http://host.docker.internal:11434

# PiKaOs — PROD-MODE docker run: env template. Copy to deploy/.env.prod (GITIGNORED) and fill with
# REAL strong secrets, then run the prod overlays (deploy.md §2.7). Generate secrets, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"   # JWT_SECRET / SECRET_KEY  (>=32 chars)
#   python -c "import secrets; print(secrets.token_hex(16))"   # passwords
# Datastores are treated as EXTERNAL via host.docker.internal (swap to real RDS/ElastiCache/S3 hosts
# the same way — only these values change, no code change).
ENVIRONMENT=production
COOKIE_SECURE=true

# --- datastore init creds (data stack bakes these; app connects via host.docker.internal) ---
POSTGRES_USER=pikaos
POSTGRES_DB=pikaos
POSTGRES_PASSWORD=__change_me__
REDIS_PASSWORD=__change_me__
MINIO_ROOT_USER=pikaosadmin
MINIO_ROOT_PASSWORD=__change_me__

# --- app-side connection URLs (datastores are EXTERNAL) ---
DATABASE_URL=postgresql+asyncpg://pikaos:__change_me__@host.docker.internal:5432/pikaos
REDIS_URL=redis://:__change_me__@host.docker.internal:6379/0
MINIO_ENDPOINT=host.docker.internal:9000
MINIO_SECURE=false
MINIO_ACCESS_KEY=pikaosadmin
MINIO_SECRET_KEY=__change_me__
MINIO_BUCKET=pikaos
STORAGE_PROVIDER=minio
STORAGE_REGION=

# --- auth secrets (>=32 chars to pass the prod guard; SECRET_KEY identical on backend+worker) ---
JWT_SECRET=__change_me_min_32_chars__
SECRET_KEY=__change_me_min_32_chars__
SEED_PASSWORD=__change_me__

# --- web ---
CORS_ORIGINS=http://localhost
WEB_CONCURRENCY=2

# PiKaOs — BACKEND stack env (API · worker · Postgres · Redis · MinIO).
# Copy to Backend/.env. Loaded by the db/redis/minio (deploy/docker-compose.data.yml), backend
# (backend.yml) and worker (ai.yml) services via env_file. 🔒 = secret → change for any shared/prod
# deploy; the backend refuses to boot in
# ENVIRONMENT=production while a 🔒 still holds a dev default (config.production_violations()).
#
# Keep comments on their OWN lines — compose reads "VAR=val # x" as the literal value "val # x".
# Pairs marked "must match" have to stay equal (one var feeds the image, the other the app).

# ── environment ──
ENVIRONMENT=development
# 🔒 true behind HTTPS in production
COOKIE_SECURE=false

# ── Postgres (db image reads POSTGRES_*; the app reads DATABASE_URL — must match) ──
POSTGRES_USER=pikaos
# 🔒
POSTGRES_PASSWORD=pikaos
POSTGRES_DB=pikaos
DATABASE_URL=postgresql+asyncpg://pikaos:pikaos@db:5432/pikaos
# 🔒 Redis auth. Empty = no auth (OK only on a private network). In production / multi-server the
# backend REFUSES TO BOOT unless REDIS_URL has a password — set REDIS_PASSWORD here AND embed it in
# REDIS_URL: REDIS_PASSWORD=<pw> and REDIS_URL=redis://:<pw>@redis:6379/0 (the two must match).
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ── auth secrets 🔒 (strong, unique, >= 32 chars) ──
JWT_SECRET=dev-secret-change-me
# empty → derives from JWT_SECRET; give it its own strong value in prod
SECRET_KEY=
# 🔒 password for all seeded users
SEED_PASSWORD=pikaos123

# ── object storage (MinIO / AWS S3) ──
# MinIO server reads MINIO_ROOT_*; the app reads MINIO_ACCESS_KEY/MINIO_SECRET_KEY — each pair must match.
# Switch to AWS S3: STORAGE_PROVIDER=s3, MINIO_ENDPOINT=s3.<region>.amazonaws.com, MINIO_SECURE=true,
# STORAGE_REGION=<region>, and put the AWS keys in MINIO_ACCESS_KEY/MINIO_SECRET_KEY.
STORAGE_PROVIDER=minio
STORAGE_REGION=
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
MINIO_ROOT_USER=pikaos
# 🔒
MINIO_ROOT_PASSWORD=pikaos-secret
MINIO_ACCESS_KEY=pikaos
# 🔒
MINIO_SECRET_KEY=pikaos-secret
MINIO_BUCKET=pikaos

# ── web ──
CORS_ORIGINS=http://localhost:5173
# 🔒 optional host allowlist for the outbound Compare fetch (SSRF guard)
COMPARE_URL_ALLOWLIST=

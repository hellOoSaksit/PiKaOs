# import-linter — the static gate behind plugin-architecture.md §2 + §15.
# Run from Backend/:  lint-imports
# grimp parses the source (it does NOT import/execute modules) so this needs no app deps installed.
#
# Two rules, both architectural invariants the Loader can't catch at import time:
#   1. Core ↛ plugins   (§2.1) — the Base never reaches up into a feature; remove any plugin and
#      Core still imports. The ONE exception is the engine (worker.py) running a knowledge job
#      lazily — that coupling moves to DI / the Event Bus in Phase 3 (ignore_imports below).
#   2. Plugin ↛ sibling plugin (§2.3) — features talk only through Core contracts, never each other.
#      Add every new app.plugins.<id> to the independence contract as it lands.

[importlinter]
root_package = app

[importlinter:contract:core-must-not-import-plugins]
name = Core (Base) must not import any plugin (§2.1)
type = forbidden
source_modules =
    app.main
    app.worker
    app.config
    app.db
    app.deps
    app.models
    app.schemas
    app.storage
    app.crypto
    app.security
    app.queue
    app.redis_client
    app.logging_ctx
    app.routers
    app.services
    app.repositories
forbidden_modules =
    app.plugins
# Phase-3 debt: the engine (arq worker) still imports the knowledge plugin directly to run its
# ingestion job + build the retriever. Phase 3 replaces these with a DI-resolved knowledge.Retriever
# contract + Event Bus; until then they are the single, documented exception.
ignore_imports =
    app.worker -> app.plugins.knowledge.ingestion_service
    app.worker -> app.plugins.knowledge.retriever

[importlinter:contract:plugins-are-independent]
name = Plugins must not import sibling plugins (§2.3)
type = independence
modules =
    app.plugins.knowledge

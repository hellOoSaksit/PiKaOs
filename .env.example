# PiKaOs — environment config. Copy to .env and set strong values for any shared/prod deploy.
# docker-compose auto-loads .env and forwards these to the backend + worker (docker-compose.yml,
# x-backend-env). 🔒 = secret / risky → MUST change before production. The backend REFUSES TO BOOT
# in ENVIRONMENT=production while any 🔒 still holds a dev default (config.production_violations()).
# All secrets live here (.env only, never in code or the UI) — this is the root of trust.
#
# NOTE: do NOT put inline comments after a value (compose reads "VAR=val # x" as the literal
# "val # x"). Keep every comment on its own line, like this file does.

# ── environment ──
# production | development — "production" turns on the boot security guard.
ENVIRONMENT=development
# 🔒 must be true behind HTTPS in production.
COOKIE_SECURE=false

# ── database (Postgres) — compose builds DATABASE_URL from these ──
POSTGRES_USER=pikaos
# 🔒 change in prod
POSTGRES_PASSWORD=pikaos
POSTGRES_DB=pikaos

# ── secrets 🔒 (use strong, unique values; >= 32 chars) ──
# 🔒 signs access tokens.
JWT_SECRET=dev-secret-change-me
# 🔒 at-rest encryption key for stored LLM API keys (app/crypto.py). Leave EMPTY to derive it from
# JWT_SECRET; in prod give it its own strong value. Changing it invalidates every stored LLM key.
SECRET_KEY=
# 🔒 password for all seeded users — change in prod.
SEED_PASSWORD=pikaos123

# ── object storage (MinIO / AWS S3 — switch provider here, no code change) ──
# minio | s3 (label; the client speaks S3 either way).
STORAGE_PROVIDER=minio
# AWS region for S3 (e.g. ap-southeast-1); MinIO ignores it.
STORAGE_REGION=
# For AWS S3 use: s3.<region>.amazonaws.com
MINIO_ENDPOINT=minio:9000
# 🔒 true for S3 / any TLS endpoint.
MINIO_SECURE=false
# 🔒 = AWS_ACCESS_KEY_ID when STORAGE_PROVIDER=s3.
MINIO_ACCESS_KEY=pikaos
# 🔒 = AWS_SECRET_ACCESS_KEY when STORAGE_PROVIDER=s3 — change in prod.
MINIO_SECRET_KEY=pikaos-secret
MINIO_BUCKET=pikaos

# ── LLM / embeddings — OPTIONAL .env fallback ──
# Most LLM config is set at runtime from the "จัดการเครื่องมือ" tools screen + DB (encrypted).
# These are used only when no DB connection is active.
# stub | ollama | openai | anthropic
LLM_PROVIDER=stub
LLM_BASE_URL=http://host.docker.internal:11434
# 🔒
OPENAI_API_KEY=
# 🔒
ANTHROPIC_API_KEY=
# stub | ollama
EMBED_PROVIDER=stub
EMBED_BASE_URL=http://host.docker.internal:11434

# ── web ──
# comma-separated allowed origins.
CORS_ORIGINS=http://localhost:5173
# 🔒 optional host allowlist for the outbound Compare fetch (SSRF guard).
COMPARE_URL_ALLOWLIST=
